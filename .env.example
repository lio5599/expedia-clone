# Example environment variables for configuring API base URL
# Option A: set full API URL (preferred)
REACT_APP_API=http://localhost:8080

# Option B: set host and port separately (fallback will be used if REACT_APP_API is not set)
#REACT_APP_API_HOST=localhost
#REACT_APP_API_PORT=8080

# Note: create a local .env file in project root with the values you need.
# After changing env vars, restart the dev server (npm start) to pick them up.
